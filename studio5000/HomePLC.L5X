<DataValueMember Name="TT" DataType="BOOL" Value="0"/>
<DataValueMember Name="DN" DataType="BOOL" Value="0"/>
</Structure>
</Data>
</Tag>
<Tag Name="Elec_Overload_Timer" TagType="Base" DataType="TIMER" Constant="false" ExternalAccess="Read/Write">
<Description><![CDATA[5s sustained overload detection]]></Description>
<Data Format="L5K"><![CDATA[[0,5000,0]]]></Data>
<Data Format="Decorated">
<Structure DataType="TIMER">
<DataValueMember Name="PRE" DataType="DINT" Radix="Decimal" Value="5000"/>
<DataValueMember Name="ACC" DataType="DINT" Radix="Decimal" Value="0"/>
<DataValueMember Name="EN" DataType="BOOL" Value="0"/>
<DataValueMember Name="TT" DataType="BOOL" Value="0"/>
<DataValueMember Name="DN" DataType="BOOL" Value="0"/>
</Structure>
</Data>
</Tag>
<Tag Name="Elec_Gen_Overload_Timer" TagType="Base" DataType="TIMER" Constant="false" ExternalAccess="Read/Write">
<Description><![CDATA[3s generator overload detection]]></Description>
<Data Format="L5K"><![CDATA[[0,3000,0]]]></Data>
<Data Format="Decorated">
<Structure DataType="TIMER">
<DataValueMember Name="PRE" DataType="DINT" Radix="Decimal" Value="3000"/>
<DataValueMember Name="ACC" DataType="DINT" Radix="Decimal" Value="0"/>
<DataValueMember Name="EN" DataType="BOOL" Value="0"/>
<DataValueMember Name="TT" DataType="BOOL" Value="0"/>
<DataValueMember Name="DN" DataType="BOOL" Value="0"/>
</Structure>
</Data>
</Tag>
<Tag Name="Load_Shed_Timer" TagType="Base" DataType="TIMER" Constant="false" ExternalAccess="Read/Write">
<Description><![CDATA[10s sustained overload for load shed]]></Description>
<Data Format="L5K"><![CDATA[[0,10000,0]]]></Data>
<Data Format="Decorated">
<Structure DataType="TIMER">
<DataValueMember Name="PRE" DataType="DINT" Radix="Decimal" Value="10000"/>
<DataValueMember Name="ACC" DataType="DINT" Radix="Decimal" Value="0"/>
<DataValueMember Name="EN" DataType="BOOL" Value="0"/>
<DataValueMember Name="TT" DataType="BOOL" Value="0"/>
<DataValueMember Name="DN" DataType="BOOL" Value="0"/>
</Structure>
</Data>
</Tag>
<Tag Name="Well_Short_Cycle_Timer" TagType="Base" DataType="TIMER" Constant="false" ExternalAccess="Read/Write">
<Description><![CDATA[60s well pump short cycle detection]]></Description>
<Data Format="L5K"><![CDATA[[0,60000,0]]]></Data>
<Data Format="Decorated">
<Structure DataType="TIMER">
<DataValueMember Name="PRE" DataType="DINT" Radix="Decimal" Value="60000"/>
<DataValueMember Name="ACC" DataType="DINT" Radix="Decimal" Value="0"/>
<DataValueMember Name="EN" DataType="BOOL" Value="0"/>
<DataValueMember Name="TT" DataType="BOOL" Value="0"/>
<DataValueMember Name="DN" DataType="BOOL" Value="0"/>
</Structure>
</Data>
</Tag>
</Tags>
<Programs>
<Program Name="MainProgram" TestEdits="false" MainRoutineName="MainRoutine" Disabled="false" UseAsFolder="false">
<Tags/>
<Routines>
<Routine Name="MainRoutine" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment><![CDATA[Call Input Mapping]]></Comment>
<Text><![CDATA[JSR(Input_Mapping,0);]]></Text>
</Rung>
<Rung Number="1" Type="N">
<Comment><![CDATA[Call Generator Control]]></Comment>
<Text><![CDATA[JSR(Generator_Control,0);]]></Text>
</Rung>
<Rung Number="2" Type="N">
<Comment><![CDATA[Call Sump Pump Control]]></Comment>
<Text><![CDATA[JSR(Sump_Pump_Control,0);]]></Text>
</Rung>
<Rung Number="3" Type="N">
<Comment><![CDATA[Call HVAC Monitor]]></Comment>
<Text><![CDATA[JSR(HVAC_Monitor,0);]]></Text>
</Rung>
<Rung Number="4" Type="N">
<Comment><![CDATA[Call Electrical Monitor]]></Comment>
<Text><![CDATA[JSR(Electrical_Monitor,0);]]></Text>
</Rung>
<Rung Number="5" Type="N">
<Comment><![CDATA[Call Leak Detection]]></Comment>
<Text><![CDATA[JSR(Leak_Detection,0);]]></Text>
</Rung>
<Rung Number="6" Type="N">
<Comment><![CDATA[Call Garage Monitor]]></Comment>
<Text><![CDATA[JSR(Garage_Monitor,0);]]></Text>
</Rung>
<Rung Number="7" Type="N">
<Comment><![CDATA[Call Well Pump Monitor]]></Comment>
<Text><![CDATA[JSR(Well_Pump_Monitor,0);]]></Text>
</Rung>
<Rung Number="8" Type="N">
<Comment><![CDATA[Call Maintenance Monitor]]></Comment>
<Text><![CDATA[JSR(Maintenance_Monitor,0);]]></Text>
</Rung>
<Rung Number="9" Type="N">
<Comment><![CDATA[Call HMI Interface]]></Comment>
<Text><![CDATA[JSR(HMI_Interface,0);]]></Text>
</Rung>
<Rung Number="10" Type="N">
<Comment><![CDATA[Call Output Mapping]]></Comment>
<Text><![CDATA[JSR(Output_Mapping,0);]]></Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="Input_Mapping" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment><![CDATA[Pt00: Utility power present]]></Comment>
<Text><![CDATA[XIC(Local:1:I.Pt00.Data)OTE(Utility_Power_Present);]]></Text>
</Rung>
<Rung Number="1" Type="N">
<Comment><![CDATA[Pt01: Generator running feedback]]></Comment>
<Text><![CDATA[XIC(Local:1:I.Pt01.Data)OTE(Gen_Running);]]></Text>
</Rung>
<Rung Number="2" Type="N">
<Comment><![CDATA[Pt02: Generator fault]]></Comment>
<Text><![CDATA[XIC(Local:1:I.Pt02.Data)OTE(Gen_Fault);]]></Text>
</Rung>
<Rung Number="3" Type="N">
<Comment><![CDATA[Pt03: Generator ready]]></Comment>
<Text><![CDATA[XIC(Local:1:I.Pt03.Data)OTE(Gen_Ready);]]></Text>
</Rung>
<Rung Number="4" Type="N">
<Comment><![CDATA[Pt04: ATS utility position]]></Comment>
<Text><![CDATA[XIC(Local:1:I.Pt04.Data)OTE(ATS_Utility_Pos);]]></Text>
</Rung>
<Rung Number="5" Type="N">
<Comment><![CDATA[Pt05: ATS generator position]]></Comment>
<Text><![CDATA[XIC(Local:1:I.Pt05.Data)OTE(ATS_Generator_Pos);]]></Text>
</Rung>
<Rung Number="6" Type="N">
<Comment><![CDATA[Pt06: Sump pit float switch]]></Comment>
<Text><![CDATA[XIC(Local:1:I.Pt06.Data)OTE(Sump_Float_High);]]></Text>
</Rung>
<Rung Number="7" Type="N">
<Comment><![CDATA[Pt07: Thermostat heat call]]></Comment>
<Text><![CDATA[XIC(Local:1:I.Pt07.Data)OTE(Thermostat_W_Call);]]></Text>
</Rung>
<Rung Number="8" Type="N">
<Comment><![CDATA[Outdoor temp: subtract 20% offset (4mA on 0-20mA range)]]></Comment>
<Text><![CDATA[SUB(Local:3:I.Ch00.Data,20.0,Outdoor_Temp_F);]]></Text>
</Rung>
<Rung Number="9" Type="N">
<Comment><![CDATA[Outdoor temp: scale 0-80% to -40 to 120F (x2.0 - 40)]]></Comment>
<Text><![CDATA[MUL(Outdoor_Temp_F,2.0,Outdoor_Temp_F);]]></Text>
</Rung>
<Rung Number="10" Type="N">
<Comment><![CDATA[Outdoor temp: offset -40F]]></Comment>
<Text><![CDATA[SUB(Outdoor_Temp_F,40.0,Outdoor_Temp_F);]]></Text>
</Rung>
<Rung Number="11" Type="N">
<Comment><![CDATA[House current: subtract 20% offset (4mA on 0-20mA range)]]></Comment>
<Text><![CDATA[SUB(Local:3:I.Ch01.Data,20.0,House_Current_Amps);]]></Text>
</Rung>
<Rung Number="12" Type="N">
<Comment><![CDATA[House current: scale 0-80% to 0-200A (x2.5)]]></Comment>
<Text><![CDATA[MUL(House_Current_Amps,2.5,House_Current_Amps);]]></Text>
</Rung>
<Rung Number="13" Type="N">
<Comment><![CDATA[Clamp outdoor temp low]]></Comment>
<Text><![CDATA[LES(Outdoor_Temp_F,-40.0)MOV(-40.0,Outdoor_Temp_F);]]></Text>
</Rung>
<Rung Number="14" Type="N">
<Comment><![CDATA[Clamp outdoor temp high]]></Comment>
<Text><![CDATA[GRT(Outdoor_Temp_F,120.0)MOV(120.0,Outdoor_Temp_F);]]></Text>
</Rung>
<Rung Number="15" Type="N">
<Comment><![CDATA[Clamp current low]]></Comment>
<Text><![CDATA[LES(House_Current_Amps,0.0)MOV(0.0,House_Current_Amps);]]></Text>
</Rung>
<Rung Number="16" Type="N">
<Comment><![CDATA[Clamp current high]]></Comment>
<Text><![CDATA[GRT(House_Current_Amps,200.0)MOV(200.0,House_Current_Amps);]]></Text>
</Rung>
<Rung Number="17" Type="N">
<Comment><![CDATA[Pt08: Leak sensor zone 1]]></Comment>
<Text><![CDATA[XIC(Local:1:I.Pt08.Data)OTE(Leak_Zone1);]]></Text>
</Rung>
<Rung Number="18" Type="N">
<Comment><![CDATA[Pt09: Leak sensor zone 2]]></Comment>
<Text><![CDATA[XIC(Local:1:I.Pt09.Data)OTE(Leak_Zone2);]]></Text>
</Rung>
<Rung Number="19" Type="N">
<Comment><![CDATA[Pt10: Leak sensor zone 3]]></Comment>
<Text><![CDATA[XIC(Local:1:I.Pt10.Data)OTE(Leak_Zone3);]]></Text>
</Rung>
<Rung Number="20" Type="N">
<Comment><![CDATA[Pt11: Garage door closed limit switch NC]]></Comment>
<Text><![CDATA[XIC(Local:1:I.Pt11.Data)OTE(Garage_Door_Closed);]]></Text>
</Rung>
<Rung Number="21" Type="N">
<Comment><![CDATA[Pt12: Well pump running feedback]]></Comment>
<Text><![CDATA[XIC(Local:1:I.Pt12.Data)OTE(Well_Pump_Running);]]></Text>
</Rung>
<Rung Number="22" Type="N">
<Comment><![CDATA[Water pressure: subtract 20% offset (4mA)]]></Comment>
<Text><![CDATA[SUB(Local:3:I.Ch02.Data,20.0,Water_Pressure_Raw);]]></Text>
</Rung>
<Rung Number="23" Type="N">
<Comment><![CDATA[Water pressure: scale to 0-100 PSI (x1.25)]]></Comment>
<Text><![CDATA[MUL(Water_Pressure_Raw,1.25,Water_Pressure_PSI);]]></Text>
</Rung>
<Rung Number="24" Type="N">
<Comment><![CDATA[Clamp water pressure low]]></Comment>
<Text><![CDATA[LES(Water_Pressure_PSI,0.0)MOV(0.0,Water_Pressure_PSI);]]></Text>
</Rung>
<Rung Number="25" Type="N">
<Comment><![CDATA[Clamp water pressure high]]></Comment>
<Text><![CDATA[GRT(Water_Pressure_PSI,100.0)MOV(100.0,Water_Pressure_PSI);]]></Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="Generator_Control" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment><![CDATA[Power loss confirm delay 5s]]></Comment>
<Text><![CDATA[XIO(Utility_Power_Present)TON(Power_Loss_Delay,5000,0);]]></Text>
</Rung>
<Rung Number="1" Type="N">
<Comment><![CDATA[Generator crank timeout 30s]]></Comment>
<Text><![CDATA[[EQU(Gen_State,20),EQU(Gen_State,95)]TON(Gen_Start_Timeout,30000,0);]]></Text>
</Rung>
<Rung Number="2" Type="N">
<Comment><![CDATA[Generator warmup 30s]]></Comment>
<Text><![CDATA[EQU(Gen_State,30)TON(Gen_Warmup_Timer,30000,0);]]></Text>
</Rung>
<Rung Number="3" Type="N">
<Comment><![CDATA[Generator cooldown 120s]]></Comment>
<Text><![CDATA[[EQU(Gen_State,60),EQU(Gen_State,105)]TON(Gen_Cooldown_Timer,120000,0);]]></Text>
</Rung>
<Rung Number="4" Type="N">
<Comment><![CDATA[Generator stop timeout 30s]]></Comment>
<Text><![CDATA[[EQU(Gen_State,70),EQU(Gen_State,110)]TON(Gen_Stop_Timeout,30000,0);]]></Text>
</Rung>
<Rung Number="5" Type="N">
<Comment><![CDATA[Exercise run timer 15min]]></Comment>
<Text><![CDATA[EQU(Gen_State,100)TON(Exercise_Run_Timer,900000,0);]]></Text>
</Rung>
<Rung Number="6" Type="N">
<Comment><![CDATA[ATS transfer delay 3s]]></Comment>
<Text><![CDATA[EQU(Gen_State,40)TON(Transfer_Delay,3000,0);]]></Text>
</Rung>
<Rung Number="7" Type="N">
<Comment><![CDATA[Utility return stability 5s]]></Comment>
<Text><![CDATA[EQU(Gen_State,50)XIC(Utility_Power_Present)TON(Gen_Utility_Return_Timer,5000,0);]]></Text>
</Rung>
<Rung Number="8" Type="N">
<Comment><![CDATA[1-second pulse timer]]></Comment>
<Text><![CDATA[XIO(Pulse_1s)TON(Pulse_1s_Timer,1000,0);]]></Text>
</Rung>
<Rung Number="9" Type="N">
<Comment><![CDATA[1-second pulse output]]></Comment>
<Text><![CDATA[XIC(Pulse_1s_Timer.DN)OTE(Pulse_1s);]]></Text>
</Rung>
<Rung Number="10" Type="N">
<Comment><![CDATA[Count seconds for weekly exercise schedule]]></Comment>
<Text><![CDATA[XIC(Pulse_1s)ONS(Exercise_Count_ONS)ADD(Exercise_Seconds,1,Exercise_Seconds);]]></Text>
</Rung>
<Rung Number="11" Type="N">
<Comment><![CDATA[Trigger exercise at 1 week (604800s)]]></Comment>
<Text><![CDATA[GEQ(Exercise_Seconds,604800)OTL(Exercise_Trigger);]]></Text>
</Rung>
<Rung Number="12" Type="N">
<Comment><![CDATA[Reset exercise second counter after trigger]]></Comment>
<Text><![CDATA[XIC(Exercise_Trigger)MOV(0,Exercise_Seconds);]]></Text>
</Rung>
<Rung Number="13" Type="N">
<Comment><![CDATA[HMI manual exercise request]]></Comment>
<Text><![CDATA[XIC(HMI_Exercise_Request)OTL(Exercise_Trigger);]]></Text>
</Rung>
<Rung Number="14" Type="N">
<Comment><![CDATA[Clear HMI exercise request]]></Comment>
<Text><![CDATA[XIC(HMI_Exercise_Request)OTU(HMI_Exercise_Request);]]></Text>
</Rung>
<Rung Number="15" Type="N">
<Comment><![CDATA[Set exercise timer preset from duration setting]]></Comment>
<Text><![CDATA[EQU(Gen_State,0)MUL(Exercise_Duration_Minutes,60000,Exercise_Run_Timer.PRE);]]></Text>
</Rung>
<Rung Number="16" Type="N">
<Comment><![CDATA[Gen start cmd - active in run/warmup/transfer/exercise states]]></Comment>
<Text><![CDATA[[EQU(Gen_State,10),EQU(Gen_State,20),EQU(Gen_State,30),EQU(Gen_State,40),EQU(Gen_State,50),EQU(Gen_State,55),EQU(Gen_State,60),EQU(Gen_State,90),EQU(Gen_State,95),EQU(Gen_State,100),EQU(Gen_State,105)]OTE(Gen_Start_Cmd);]]></Text>
</Rung>
<Rung Number="17" Type="N">
<Comment><![CDATA[ATS transfer cmd - active during generator operation]]></Comment>
<Text><![CDATA[[EQU(Gen_State,40),EQU(Gen_State,50)]OTE(ATS_Transfer_Cmd);]]></Text>
</Rung>
<Rung Number="18" Type="N">
<Comment><![CDATA[On utility power flag]]></Comment>
<Text><![CDATA[[EQU(Gen_State,0),EQU(Gen_State,55),EQU(Gen_State,60),EQU(Gen_State,70),EQU(Gen_State,90),EQU(Gen_State,95),EQU(Gen_State,100),EQU(Gen_State,105),EQU(Gen_State,110),EQU(Gen_State,999)]OTE(Gen_On_Utility);]]></Text>
</Rung>
<Rung Number="19" Type="N">
<Comment><![CDATA[On generator power flag]]></Comment>
<Text><![CDATA[EQU(Gen_State,50)OTE(Gen_On_Generator);]]></Text>
</Rung>
<Rung Number="20" Type="N">
<Comment><![CDATA[Exercise active flag]]></Comment>
<Text><![CDATA[[EQU(Gen_State,90),EQU(Gen_State,95),EQU(Gen_State,100),EQU(Gen_State,105)]OTE(Gen_Exercise_Active);]]></Text>
</Rung>
<Rung Number="21" Type="N">
<Comment><![CDATA[State 0->10: Power loss confirmed]]></Comment>
<Text><![CDATA[EQU(Gen_State,0)XIC(Power_Loss_Delay.DN)MOV(10,Gen_State);]]></Text>
</Rung>
<Rung Number="22" Type="N">
<Comment><![CDATA[State 0->90: Exercise trigger, no fault]]></Comment>
<Text><![CDATA[EQU(Gen_State,0)XIC(Exercise_Trigger)XIO(Gen_Fault)XIO(Power_Loss_Delay.DN)MOV(90,Gen_State);]]></Text>
</Rung>
<Rung Number="23" Type="N">
<Comment><![CDATA[State 90: Clear exercise trigger]]></Comment>
<Text><![CDATA[EQU(Gen_State,90)OTU(Exercise_Trigger);]]></Text>
</Rung>
<Rung Number="24" Type="N">
<Comment><![CDATA[State 10->20: Start commanded]]></Comment>
<Text><![CDATA[EQU(Gen_State,10)MOV(20,Gen_State);]]></Text>
</Rung>
<Rung Number="25" Type="N">
<Comment><![CDATA[State 20->30: Generator running confirmed]]></Comment>
<Text><![CDATA[EQU(Gen_State,20)XIC(Gen_Running)MOV(30,Gen_State);]]></Text>
</Rung>
<Rung Number="26" Type="N">
<Comment><![CDATA[State 20: Increment crank attempts on timeout]]></Comment>
<Text><![CDATA[EQU(Gen_State,20)XIC(Gen_Start_Timeout.DN)ONS(Crank_Attempt_ONS)ADD(Gen_Crank_Attempts,1,Gen_Crank_Attempts);]]></Text>
</Rung>
<Rung Number="27" Type="N">
<Comment><![CDATA[State 20->999: Start fail after 3 attempts]]></Comment>
<Text><![CDATA[EQU(Gen_State,20)XIC(Gen_Start_Timeout.DN)GEQ(Gen_Crank_Attempts,3)OTL(Gen_Start_Fail);]]></Text>
</Rung>
<Rung Number="28" Type="N">
<Text><![CDATA[EQU(Gen_State,20)XIC(Gen_Start_Timeout.DN)GEQ(Gen_Crank_Attempts,3)MOV(999,Gen_State);]]></Text>
</Rung>
<Rung Number="29" Type="N">
<Comment><![CDATA[State 20->10: Retry start (under 3 attempts)]]></Comment>
<Text><![CDATA[EQU(Gen_State,20)XIC(Gen_Start_Timeout.DN)LES(Gen_Crank_Attempts,3)MOV(10,Gen_State);]]></Text>
</Rung>
<Rung Number="30" Type="N">
<Comment><![CDATA[State 30->40: Warmup complete]]></Comment>
<Text><![CDATA[EQU(Gen_State,30)XIC(Gen_Warmup_Timer.DN)MOV(40,Gen_State);]]></Text>
</Rung>
<Rung Number="31" Type="N">
<Comment><![CDATA[State 30->999: Fault during warmup]]></Comment>
<Text><![CDATA[EQU(Gen_State,30)XIC(Gen_Fault)MOV(999,Gen_State);]]></Text>
</Rung>
<Rung Number="32" Type="N">
<Comment><![CDATA[State 40->50: ATS transfer confirmed]]></Comment>
<Text><![CDATA[EQU(Gen_State,40)XIC(Transfer_Delay.DN)XIC(ATS_Generator_Pos)MOV(50,Gen_State);]]></Text>
</Rung>
<Rung Number="33" Type="N">
<Comment><![CDATA[State 40->999: Fault during transfer]]></Comment>
<Text><![CDATA[EQU(Gen_State,40)XIC(Gen_Fault)MOV(999,Gen_State);]]></Text>
</Rung>
<Rung Number="34" Type="N">
<Comment><![CDATA[State 50: Track generator run time]]></Comment>
<Text><![CDATA[EQU(Gen_State,50)XIC(Pulse_1s)ADD(Gen_Total_Run_Seconds,1,Gen_Total_Run_Seconds);]]></Text>
</Rung>
<Rung Number="35" Type="N">
<Comment><![CDATA[State 50->55: Utility returned stable 5s]]></Comment>
<Text><![CDATA[EQU(Gen_State,50)XIC(Gen_Utility_Return_Timer.DN)MOV(55,Gen_State);]]></Text>
</Rung>
<Rung Number="36" Type="N">
<Comment><![CDATA[State 50->999: Fault while on generator]]></Comment>
<Text><![CDATA[EQU(Gen_State,50)XIC(Gen_Fault)MOV(999,Gen_State);]]></Text>
</Rung>
<Rung Number="37" Type="N">
<Comment><![CDATA[State 55->60: ATS back to utility confirmed]]></Comment>
<Text><![CDATA[EQU(Gen_State,55)XIC(ATS_Utility_Pos)MOV(60,Gen_State);]]></Text>
</Rung>
<Rung Number="38" Type="N">
<Comment><![CDATA[State 60->70: Cooldown complete]]></Comment>
<Text><![CDATA[EQU(Gen_State,60)XIC(Gen_Cooldown_Timer.DN)MOV(70,Gen_State);]]></Text>
</Rung>
<Rung Number="39" Type="N">
<Comment><![CDATA[State 70: Clear crank attempts on successful stop]]></Comment>
<Text><![CDATA[EQU(Gen_State,70)XIO(Gen_Running)MOV(0,Gen_Crank_Attempts);]]></Text>
</Rung>
<Rung Number="40" Type="N">
<Comment><![CDATA[State 70->0: Generator stopped]]></Comment>
<Text><![CDATA[EQU(Gen_State,70)XIO(Gen_Running)MOV(0,Gen_State);]]></Text>
</Rung>
<Rung Number="41" Type="N">
<Comment><![CDATA[State 70->999: Stop timeout]]></Comment>
<Text><![CDATA[EQU(Gen_State,70)XIC(Gen_Stop_Timeout.DN)OTL(Gen_Stop_Fail);]]></Text>
</Rung>
<Rung Number="42" Type="N">
<Text><![CDATA[EQU(Gen_State,70)XIC(Gen_Stop_Timeout.DN)MOV(999,Gen_State);]]></Text>
</Rung>
<Rung Number="43" Type="N">
<Comment><![CDATA[State 90->95: Exercise start transition]]></Comment>
<Text><![CDATA[EQU(Gen_State,90)MOV(95,Gen_State);]]></Text>
</Rung>
<Rung Number="44" Type="N">
<Comment><![CDATA[State 95->100: Exercise generator running]]></Comment>
<Text><![CDATA[EQU(Gen_State,95)XIC(Gen_Running)MOV(100,Gen_State);]]></Text>
</Rung>
<Rung Number="45" Type="N">
<Comment><![CDATA[State 95->999: Exercise start timeout]]></Comment>
<Text><![CDATA[EQU(Gen_State,95)XIC(Gen_Start_Timeout.DN)OTL(Gen_Start_Fail);]]></Text>
</Rung>
<Rung Number="46" Type="N">
<Text><![CDATA[EQU(Gen_State,95)XIC(Gen_Start_Timeout.DN)MOV(999,Gen_State);]]></Text>
</Rung>
<Rung Number="47" Type="N">
<Comment><![CDATA[State 100: Track exercise run time]]></Comment>
<Text><![CDATA[EQU(Gen_State,100)XIC(Pulse_1s)ADD(Gen_Total_Run_Seconds,1,Gen_Total_Run_Seconds);]]></Text>
</Rung>
<Rung Number="48" Type="N">
<Comment><![CDATA[State 100->105: Exercise run complete]]></Comment>
<Text><![CDATA[EQU(Gen_State,100)XIC(Exercise_Run_Timer.DN)MOV(105,Gen_State);]]></Text>
</Rung>
<Rung Number="49" Type="N">
<Comment><![CDATA[State 100->30: Power loss during exercise - switch to real operation]]></Comment>
<Text><![CDATA[EQU(Gen_State,100)XIO(Utility_Power_Present)MOV(30,Gen_State);]]></Text>
</Rung>
<Rung Number="50" Type="N">
<Comment><![CDATA[State 100->999: Fault during exercise]]></Comment>
<Text><![CDATA[EQU(Gen_State,100)XIC(Gen_Fault)MOV(999,Gen_State);]]></Text>
</Rung>
<Rung Number="51" Type="N">
<Comment><![CDATA[State 105->110: Exercise cooldown complete]]></Comment>
<Text><![CDATA[EQU(Gen_State,105)XIC(Gen_Cooldown_Timer.DN)MOV(110,Gen_State);]]></Text>
</Rung>
<Rung Number="52" Type="N">
<Comment><![CDATA[State 110: Clear crank attempts on exercise shutdown]]></Comment>
<Text><![CDATA[EQU(Gen_State,110)XIO(Gen_Running)MOV(0,Gen_Crank_Attempts);]]></Text>
</Rung>
<Rung Number="53" Type="N">
<Comment><![CDATA[State 110->0: Exercise shutdown complete]]></Comment>
<Text><![CDATA[EQU(Gen_State,110)XIO(Gen_Running)MOV(0,Gen_State);]]></Text>
</Rung>
<Rung Number="54" Type="N">
<Comment><![CDATA[State 110->999: Exercise stop timeout]]></Comment>
<Text><![CDATA[EQU(Gen_State,110)XIC(Gen_Stop_Timeout.DN)OTL(Gen_Stop_Fail);]]></Text>
</Rung>
<Rung Number="55" Type="N">
<Text><![CDATA[EQU(Gen_State,110)XIC(Gen_Stop_Timeout.DN)MOV(999,Gen_State);]]></Text>
</Rung>
<Rung Number="56" Type="N">
<Comment><![CDATA[Fault reset from HMI - clear start fail]]></Comment>
<Text><![CDATA[XIC(HMI_Gen_Fault_Reset)XIO(Gen_Fault)OTU(Gen_Start_Fail);]]></Text>
</Rung>
<Rung Number="57" Type="N">
<Comment><![CDATA[Fault reset - clear stop fail]]></Comment>
<Text><![CDATA[XIC(HMI_Gen_Fault_Reset)XIO(Gen_Fault)OTU(Gen_Stop_Fail);]]></Text>
</Rung>
<Rung Number="58" Type="N">
<Comment><![CDATA[Fault reset - clear crank attempts]]></Comment>
<Text><![CDATA[XIC(HMI_Gen_Fault_Reset)XIO(Gen_Fault)MOV(0,Gen_Crank_Attempts);]]></Text>
</Rung>
<Rung Number="59" Type="N">
<Comment><![CDATA[Fault reset - return to idle]]></Comment>
<Text><![CDATA[XIC(HMI_Gen_Fault_Reset)XIO(Gen_Fault)MOV(0,Gen_State);]]></Text>
</Rung>
<Rung Number="60" Type="N">
<Comment><![CDATA[Clear HMI fault reset]]></Comment>
<Text><![CDATA[XIC(HMI_Gen_Fault_Reset)OTU(HMI_Gen_Fault_Reset);]]></Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="Sump_Pump_Control" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment><![CDATA[Float switch debounce 2s]]></Comment>
<Text><![CDATA[XIC(Sump_Float_High)TON(Sump_Debounce,2000,0);]]></Text>
</Rung>
<Rung Number="1" Type="N">
<Comment><![CDATA[Max pump run time 5min]]></Comment>
<Text><![CDATA[XIC(Sump_Pump_Run)TON(Sump_Max_Run,300000,0);]]></Text>
</Rung>
<Rung Number="2" Type="N">
<Comment><![CDATA[Pump off delay 10s after float drops]]></Comment>
<Text><![CDATA[XIO(Sump_Float_High)XIC(Sump_Pump_Run)TON(Sump_Off_Delay,10000,0);]]></Text>
</Rung>
<Rung Number="3" Type="N">
<Comment><![CDATA[Test run timer 15s]]></Comment>
<Text><![CDATA[EQU(Sump_State,30)TON(Sump_Test_Run_Timer,15000,0);]]></Text>
</Rung>
<Rung Number="4" Type="N">
<Comment><![CDATA[Count seconds for weekly sump test]]></Comment>
<Text><![CDATA[XIC(Pulse_1s)ADD(Sump_Test_Seconds,1,Sump_Test_Seconds);]]></Text>
</Rung>
<Rung Number="5" Type="N">
<Comment><![CDATA[Trigger sump test at 1 week]]></Comment>
<Text><![CDATA[GEQ(Sump_Test_Seconds,604800)OTL(Sump_Test_Trigger);]]></Text>
</Rung>
<Rung Number="6" Type="N">
<Comment><![CDATA[Reset sump test counter after trigger]]></Comment>
<Text><![CDATA[XIC(Sump_Test_Trigger)MOV(0,Sump_Test_Seconds);]]></Text>
</Rung>
<Rung Number="7" Type="N">
<Comment><![CDATA[HMI manual sump test request]]></Comment>
<Text><![CDATA[XIC(HMI_Sump_Test_Request)OTL(Sump_Test_Trigger);]]></Text>
</Rung>
<Rung Number="8" Type="N">
<Comment><![CDATA[Clear HMI sump test request]]></Comment>
<Text><![CDATA[XIC(HMI_Sump_Test_Request)OTU(HMI_Sump_Test_Request);]]></Text>
</Rung>
<Rung Number="9" Type="N">
<Comment><![CDATA[State 0->10: Float debounced high]]></Comment>
<Text><![CDATA[EQU(Sump_State,0)XIC(Sump_Debounce.DN)MOV(10,Sump_State);]]></Text>
</Rung>
<Rung Number="10" Type="N">
<Comment><![CDATA[State 0->30: Test triggered]]></Comment>
<Text><![CDATA[EQU(Sump_State,0)XIC(Sump_Test_Trigger)XIO(Sump_Debounce.DN)MOV(30,Sump_State);]]></Text>
</Rung>
<Rung Number="11" Type="N">
<Comment><![CDATA[Clear test trigger on entry]]></Comment>
<Text><![CDATA[EQU(Sump_State,30)OTU(Sump_Test_Trigger);]]></Text>
</Rung>
<Rung Number="12" Type="N">
<Comment><![CDATA[State 10: Count pump cycle]]></Comment>
<Text><![CDATA[EQU(Sump_State,10)ONS(Sump_Cycle_ONS)ADD(Sump_Cycle_Count,1,Sump_Cycle_Count);]]></Text>
</Rung>
<Rung Number="13" Type="N">
<Comment><![CDATA[State 10->20: Start pumping]]></Comment>
<Text><![CDATA[EQU(Sump_State,10)MOV(20,Sump_State);]]></Text>
</Rung>
<Rung Number="14" Type="N">
<Comment><![CDATA[State 20: Track current run time]]></Comment>
<Text><![CDATA[EQU(Sump_State,20)XIC(Pulse_1s)ADD(Sump_Current_Run_Seconds,1,Sump_Current_Run_Seconds);]]></Text>
</Rung>
<Rung Number="15" Type="N">
<Comment><![CDATA[State 20: Track total run time]]></Comment>
<Text><![CDATA[EQU(Sump_State,20)XIC(Pulse_1s)ADD(Sump_Total_Run_Seconds,1,Sump_Total_Run_Seconds);]]></Text>
</Rung>
<Rung Number="16" Type="N">
<Comment><![CDATA[State 20->999: Max run time exceeded - set fault]]></Comment>
<Text><![CDATA[EQU(Sump_State,20)XIC(Sump_Max_Run.DN)OTL(Sump_Max_Run_Fault);]]></Text>
</Rung>
<Rung Number="17" Type="N">
<Comment><![CDATA[State 20: Save last run on fault]]></Comment>
<Text><![CDATA[EQU(Sump_State,20)XIC(Sump_Max_Run.DN)MOV(Sump_Current_Run_Seconds,Sump_Last_Run_Seconds);]]></Text>
</Rung>
<Rung Number="18" Type="N">
<Comment><![CDATA[State 20: Clear current run on fault]]></Comment>
<Text><![CDATA[EQU(Sump_State,20)XIC(Sump_Max_Run.DN)MOV(0,Sump_Current_Run_Seconds);]]></Text>
</Rung>
<Rung Number="19" Type="N">
<Comment><![CDATA[State 20->999: Transition to fault]]></Comment>
<Text><![CDATA[EQU(Sump_State,20)XIC(Sump_Max_Run.DN)MOV(999,Sump_State);]]></Text>
</Rung>
<Rung Number="20" Type="N">
<Comment><![CDATA[State 20: Save last run on completion]]></Comment>
<Text><![CDATA[EQU(Sump_State,20)XIC(Sump_Off_Delay.DN)MOV(Sump_Current_Run_Seconds,Sump_Last_Run_Seconds);]]></Text>
</Rung>
<Rung Number="21" Type="N">
<Comment><![CDATA[State 20: Clear current run on completion]]></Comment>
<Text><![CDATA[EQU(Sump_State,20)XIC(Sump_Off_Delay.DN)MOV(0,Sump_Current_Run_Seconds);]]></Text>
</Rung>
<Rung Number="22" Type="N">
<Comment><![CDATA[State 20->0: Float dropped, off delay done]]></Comment>
<Text><![CDATA[EQU(Sump_State,20)XIC(Sump_Off_Delay.DN)MOV(0,Sump_State);]]></Text>
</Rung>
<Rung Number="23" Type="N">
<Comment><![CDATA[State 30: Set test active]]></Comment>
<Text><![CDATA[EQU(Sump_State,30)OTL(Sump_Test_Active);]]></Text>
</Rung>
<Rung Number="24" Type="N">
<Comment><![CDATA[State 30->0: Test complete - clear active]]></Comment>
<Text><![CDATA[EQU(Sump_State,30)XIC(Sump_Test_Run_Timer.DN)OTU(Sump_Test_Active);]]></Text>
</Rung>
<Rung Number="25" Type="N">
<Comment><![CDATA[State 30: Set last test OK]]></Comment>
<Text><![CDATA[EQU(Sump_State,30)XIC(Sump_Test_Run_Timer.DN)OTL(Sump_Last_Test_OK);]]></Text>
</Rung>
<Rung Number="26" Type="N">
<Comment><![CDATA[State 30->0: Test complete transition]]></Comment>
<Text><![CDATA[EQU(Sump_State,30)XIC(Sump_Test_Run_Timer.DN)MOV(0,Sump_State);]]></Text>
</Rung>
<Rung Number="27" Type="N">
<Comment><![CDATA[State 30->20: Real high water during test]]></Comment>
<Text><![CDATA[EQU(Sump_State,30)XIC(Sump_Float_High)XIO(Sump_Test_Run_Timer.DN)OTU(Sump_Test_Active);]]></Text>
</Rung>
<Rung Number="28" Type="N">
<Text><![CDATA[EQU(Sump_State,30)XIC(Sump_Float_High)XIO(Sump_Test_Run_Timer.DN)MOV(20,Sump_State);]]></Text>
</Rung>
<Rung Number="29" Type="N">
<Comment><![CDATA[Sump pump run output]]></Comment>
<Text><![CDATA[[EQU(Sump_State,10),EQU(Sump_State,20),EQU(Sump_State,30),EQU(Sump_State,999)XIC(Sump_Float_High)]OTE(Sump_Pump_Run);]]></Text>
</Rung>
<Rung Number="30" Type="N">
<Comment><![CDATA[Sump fault reset from HMI]]></Comment>
<Text><![CDATA[XIC(HMI_Sump_Fault_Reset)OTU(Sump_Max_Run_Fault);]]></Text>
</Rung>
<Rung Number="31" Type="N">
<Comment><![CDATA[Sump fault reset - clear cycle rate alarm]]></Comment>
<Text><![CDATA[XIC(HMI_Sump_Fault_Reset)OTU(Sump_Cycle_Rate_Alarm);]]></Text>
</Rung>
<Rung Number="32" Type="N">
<Text><![CDATA[XIC(HMI_Sump_Fault_Reset)MOV(0,Sump_State);]]></Text>
</Rung>
<Rung Number="33" Type="N">
<Text><![CDATA[XIC(HMI_Sump_Fault_Reset)OTU(HMI_Sump_Fault_Reset);]]></Text>
</Rung>
<Rung Number="34" Type="N">
<Comment><![CDATA[Count hourly seconds]]></Comment>
<Text><![CDATA[XIC(Pulse_1s)ADD(Sump_Hourly_Seconds,1,Sump_Hourly_Seconds);]]></Text>
</Rung>
<Rung Number="35" Type="N">
<Comment><![CDATA[One-shot trigger: pump entering state 10]]></Comment>
<Text><![CDATA[EQU(Sump_State,10)XIO(Sump_Cycle_Rate_ONS)ADD(Sump_Hourly_Cycle_Count,1,Sump_Hourly_Cycle_Count);]]></Text>
</Rung>
<Rung Number="36" Type="N">
<Comment><![CDATA[Set one-shot bit when in state 10]]></Comment>
<Text><![CDATA[EQU(Sump_State,10)OTL(Sump_Cycle_Rate_ONS);]]></Text>
</Rung>
<Rung Number="37" Type="N">
<Comment><![CDATA[Clear one-shot bit when not in state 10]]></Comment>
<Text><![CDATA[NEQ(Sump_State,10)OTU(Sump_Cycle_Rate_ONS);]]></Text>
</Rung>
<Rung Number="38" Type="N">
<Comment><![CDATA[Reset hourly counter at 3600 seconds]]></Comment>
<Text><![CDATA[GEQ(Sump_Hourly_Seconds,3600)MOV(0,Sump_Hourly_Cycle_Count);]]></Text>
</Rung>
<Rung Number="39" Type="N">
<Comment><![CDATA[Reset hourly seconds at 3600]]></Comment>
<Text><![CDATA[GEQ(Sump_Hourly_Seconds,3600)MOV(0,Sump_Hourly_Seconds);]]></Text>
</Rung>
<Rung Number="40" Type="N">
<Comment><![CDATA[Cycle rate alarm when count exceeds max]]></Comment>
<Text><![CDATA[GEQ(Sump_Hourly_Cycle_Count,Sump_Cycle_Rate_Max)OTL(Sump_Cycle_Rate_Alarm);]]></Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="HVAC_Monitor" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment><![CDATA[Heat call debounce 5s]]></Comment>
<Text><![CDATA[XIC(Thermostat_W_Call)TON(Heat_Call_Debounce,5000,0);]]></Text>
</Rung>
<Rung Number="1" Type="N">
<Comment><![CDATA[Short cycle detection window 3min]]></Comment>
<Text><![CDATA[XIO(Thermostat_W_Call)XIC(HVAC_Was_Running)TON(Short_Cycle_Timer,180000,0);]]></Text>
</Rung>
<Rung Number="2" Type="N">
<Comment><![CDATA[Count furnace cycle on start]]></Comment>
<Text><![CDATA[XIC(Heat_Call_Debounce.DN)XIO(HVAC_Furnace_Running)ADD(HVAC_Cycle_Count,1,HVAC_Cycle_Count);]]></Text>
</Rung>
<Rung Number="3" Type="N">
<Comment><![CDATA[Clear current run seconds on start]]></Comment>
<Text><![CDATA[XIC(Heat_Call_Debounce.DN)XIO(HVAC_Furnace_Running)MOV(0,HVAC_Current_Run_Seconds);]]></Text>
</Rung>
<Rung Number="4" Type="N">
<Comment><![CDATA[Short cycle check - restart within 3min window]]></Comment>
<Text><![CDATA[XIC(Heat_Call_Debounce.DN)XIO(HVAC_Furnace_Running)XIC(Short_Cycle_Timer.TT)ADD(HVAC_Short_Cycle_Count,1,HVAC_Short_Cycle_Count);]]></Text>
</Rung>
<Rung Number="5" Type="N">
<Comment><![CDATA[Clear short cycle count if not short cycling]]></Comment>
<Text><![CDATA[XIC(Heat_Call_Debounce.DN)XIO(HVAC_Furnace_Running)XIO(Short_Cycle_Timer.TT)MOV(0,HVAC_Short_Cycle_Count);]]></Text>
</Rung>
<Rung Number="6" Type="N">
<Comment><![CDATA[Short cycle alarm at 3 consecutive]]></Comment>
<Text><![CDATA[GEQ(HVAC_Short_Cycle_Count,3)OTL(HVAC_Short_Cycle_Alarm);]]></Text>
</Rung>
<Rung Number="7" Type="N">
<Comment><![CDATA[Latch furnace running]]></Comment>
<Text><![CDATA[XIC(Heat_Call_Debounce.DN)OTL(HVAC_Furnace_Running);]]></Text>
</Rung>
<Rung Number="8" Type="N">
<Comment><![CDATA[Save last run on shutdown]]></Comment>
<Text><![CDATA[XIO(Thermostat_W_Call)XIC(HVAC_Furnace_Running)MOV(HVAC_Current_Run_Seconds,HVAC_Last_Run_Seconds);]]></Text>
</Rung>
<Rung Number="9" Type="N">
<Comment><![CDATA[Set was running flag]]></Comment>
<Text><![CDATA[XIO(Thermostat_W_Call)XIC(HVAC_Furnace_Running)OTL(HVAC_Was_Running);]]></Text>
</Rung>
<Rung Number="10" Type="N">
<Comment><![CDATA[Clear furnace running on shutdown]]></Comment>
<Text><![CDATA[XIO(Thermostat_W_Call)OTU(HVAC_Furnace_Running);]]></Text>
</Rung>
<Rung Number="11" Type="N">
<Comment><![CDATA[Clear was running after short cycle window]]></Comment>
<Text><![CDATA[XIC(Short_Cycle_Timer.DN)OTU(HVAC_Was_Running);]]></Text>
</Rung>
<Rung Number="12" Type="N">
<Comment><![CDATA[Track current furnace run time]]></Comment>
<Text><![CDATA[XIC(HVAC_Furnace_Running)XIC(Pulse_1s)ADD(HVAC_Current_Run_Seconds,1,HVAC_Current_Run_Seconds);]]></Text>
</Rung>
<Rung Number="13" Type="N">
<Comment><![CDATA[Track total furnace run time]]></Comment>
<Text><![CDATA[XIC(HVAC_Furnace_Running)XIC(Pulse_1s)ADD(HVAC_Total_Run_Seconds,1,HVAC_Total_Run_Seconds);]]></Text>
</Rung>
<Rung Number="14" Type="N">
<Comment><![CDATA[Track filter run time]]></Comment>
<Text><![CDATA[XIC(HVAC_Furnace_Running)XIC(Pulse_1s)ADD(HVAC_Filter_Run_Seconds,1,HVAC_Filter_Run_Seconds);]]></Text>
</Rung>
<Rung Number="15" Type="N">
<Comment><![CDATA[Filter change due at 300 hours (1080000s)]]></Comment>
<Text><![CDATA[GEQ(HVAC_Filter_Run_Seconds,1080000)OTL(HVAC_Filter_Change_Due);]]></Text>
</Rung>
<Rung Number="16" Type="N">
<Comment><![CDATA[HMI filter reset - clear hours]]></Comment>
<Text><![CDATA[XIC(HMI_Filter_Reset)MOV(0,HVAC_Filter_Run_Seconds);]]></Text>
</Rung>
<Rung Number="17" Type="N">
<Comment><![CDATA[HMI filter reset - clear flag]]></Comment>
<Text><![CDATA[XIC(HMI_Filter_Reset)OTU(HVAC_Filter_Change_Due);]]></Text>
</Rung>
<Rung Number="18" Type="N">
<Text><![CDATA[XIC(HMI_Filter_Reset)OTU(HMI_Filter_Reset);]]></Text>
</Rung>
<Rung Number="19" Type="N">
<Comment><![CDATA[Track outdoor temp minimum]]></Comment>
<Text><![CDATA[LES(Outdoor_Temp_F,HVAC_Outdoor_Temp_Min)MOV(Outdoor_Temp_F,HVAC_Outdoor_Temp_Min);]]></Text>
</Rung>
<Rung Number="20" Type="N">
<Comment><![CDATA[Track outdoor temp maximum]]></Comment>
<Text><![CDATA[GRT(Outdoor_Temp_F,HVAC_Outdoor_Temp_Max)MOV(Outdoor_Temp_F,HVAC_Outdoor_Temp_Max);]]></Text>
</Rung>
<Rung Number="21" Type="N">
<Comment><![CDATA[HMI min/max reset]]></Comment>
<Text><![CDATA[XIC(HMI_Temp_MinMax_Reset)MOV(Outdoor_Temp_F,HVAC_Outdoor_Temp_Min);]]></Text>
</Rung>
<Rung Number="22" Type="N">
<Text><![CDATA[XIC(HMI_Temp_MinMax_Reset)MOV(Outdoor_Temp_F,HVAC_Outdoor_Temp_Max);]]></Text>
</Rung>
<Rung Number="23" Type="N">
<Text><![CDATA[XIC(HMI_Temp_MinMax_Reset)OTU(HMI_Temp_MinMax_Reset);]]></Text>
</Rung>
<Rung Number="24" Type="N">
<Comment><![CDATA[HMI HVAC alarm reset]]></Comment>
<Text><![CDATA[XIC(HMI_HVAC_Alarm_Reset)OTU(HVAC_Short_Cycle_Alarm);]]></Text>
</Rung>
<Rung Number="25" Type="N">
<Text><![CDATA[XIC(HMI_HVAC_Alarm_Reset)MOV(0,HVAC_Short_Cycle_Count);]]></Text>
</Rung>
<Rung Number="26" Type="N">
<Text><![CDATA[XIC(HMI_HVAC_Alarm_Reset)OTU(HMI_HVAC_Alarm_Reset);]]></Text>
</Rung>
<Rung Number="27" Type="N">
<Comment><![CDATA[Freeze warning when temp at or below warning setpoint]]></Comment>
<Text><![CDATA[LEQ(Outdoor_Temp_F,Freeze_Warning_SP)OTL(Freeze_Warning);]]></Text>
</Rung>
<Rung Number="28" Type="N">
<Comment><![CDATA[Freeze critical when temp at or below critical setpoint]]></Comment>
<Text><![CDATA[LEQ(Outdoor_Temp_F,Freeze_Critical_SP)OTL(Freeze_Critical);]]></Text>
</Rung>
<Rung Number="29" Type="N">
<Comment><![CDATA[Clear freeze warning when temp above warning SP and HMI reset]]></Comment>
<Text><![CDATA[XIC(HMI_Freeze_Alarm_Reset)GRT(Outdoor_Temp_F,Freeze_Warning_SP)OTU(Freeze_Warning);]]></Text>
</Rung>
<Rung Number="30" Type="N">
<Comment><![CDATA[Clear freeze critical when temp above critical SP and HMI reset]]></Comment>
<Text><![CDATA[XIC(HMI_Freeze_Alarm_Reset)GRT(Outdoor_Temp_F,Freeze_Critical_SP)OTU(Freeze_Critical);]]></Text>
</Rung>
<Rung Number="31" Type="N">
<Comment><![CDATA[Clear HMI freeze alarm reset]]></Comment>
<Text><![CDATA[XIC(HMI_Freeze_Alarm_Reset)OTU(HMI_Freeze_Alarm_Reset);]]></Text>
</Rung>
<Rung Number="32" Type="N">
<Comment><![CDATA[Track daily furnace run seconds]]></Comment>
<Text><![CDATA[XIC(HVAC_Furnace_Running)XIC(Pulse_1s)ADD(HVAC_Daily_Run_Seconds,1,HVAC_Daily_Run_Seconds);]]></Text>
</Rung>
<Rung Number="33" Type="N">
<Comment><![CDATA[Count HDD hourly seconds]]></Comment>
<Text><![CDATA[XIC(Pulse_1s)ADD(HVAC_HDD_Hourly_Seconds,1,HVAC_HDD_Hourly_Seconds);]]></Text>
</Rung>
<Rung Number="34" Type="N">
<Comment><![CDATA[Accumulate HDD hourly: HDD += max(0,(65-temp)/24) every 3600s]]></Comment>
<Text><![CDATA[GEQ(HVAC_HDD_Hourly_Seconds,3600)SUB(65.0,Outdoor_Temp_F,HVAC_Daily_HDD);]]></Text>
</Rung>
<Rung Number="35" Type="N">
<Comment><![CDATA[HDD: divide by 24 for hourly fraction]]></Comment>
<Text><![CDATA[GEQ(HVAC_HDD_Hourly_Seconds,3600)DIV(HVAC_Daily_HDD,24.0,HVAC_Daily_HDD);]]></Text>
</Rung>
<Rung Number="36" Type="N">
<Comment><![CDATA[HDD: clamp negative to zero]]></Comment>
<Text><![CDATA[LES(HVAC_Daily_HDD,0.0)MOV(0.0,HVAC_Daily_HDD);]]></Text>
</Rung>
<Rung Number="37" Type="N">
<Comment><![CDATA[HDD: add hourly fraction to accumulated]]></Comment>
<Text><![CDATA[GEQ(HVAC_HDD_Hourly_Seconds,3600)ADD(HVAC_HDD_Accumulated,HVAC_Daily_HDD,HVAC_HDD_Accumulated);]]></Text>
</Rung>
<Rung Number="38" Type="N">
<Comment><![CDATA[HDD: reset hourly seconds counter]]></Comment>
<Text><![CDATA[GEQ(HVAC_HDD_Hourly_Seconds,3600)MOV(0,HVAC_HDD_Hourly_Seconds);]]></Text>
</Rung>
<Rung Number="39" Type="N">
<Comment><![CDATA[Compute runtime to HDD ratio (avoid div by zero)]]></Comment>
<Text><![CDATA[GRT(HVAC_HDD_Accumulated,0.0)DIV(HVAC_Daily_Run_Seconds,HVAC_HDD_Accumulated,HVAC_HDD_Runtime_Ratio);]]></Text>
</Rung>
<Rung Number="40" Type="N">
<Comment><![CDATA[Compute efficiency pct = ratio/baseline * 100]]></Comment>
<Text><![CDATA[GRT(HVAC_HDD_Baseline_Ratio,0.0)DIV(HVAC_HDD_Runtime_Ratio,HVAC_HDD_Baseline_Ratio,HVAC_Efficiency_Pct);]]></Text>
</Rung>
<Rung Number="41" Type="N">
<Comment><![CDATA[Scale efficiency to percentage]]></Comment>
<Text><![CDATA[MUL(HVAC_Efficiency_Pct,100.0,HVAC_Efficiency_Pct);]]></Text>
</Rung>
<Rung Number="42" Type="N">
<Comment><![CDATA[Efficiency alarm when above threshold]]></Comment>
<Text><![CDATA[GRT(HVAC_Efficiency_Pct,HVAC_Efficiency_Threshold)OTL(HVAC_Efficiency_Alarm);]]></Text>
</Rung>
<Rung Number="43" Type="N">
<Comment><![CDATA[HMI efficiency reset - clear accumulated data]]></Comment>
<Text><![CDATA[XIC(HMI_HVAC_Efficiency_Reset)MOV(0,HVAC_Daily_Run_Seconds);]]></Text>
</Rung>
<Rung Number="44" Type="N">
<Text><![CDATA[XIC(HMI_HVAC_Efficiency_Reset)MOV(0.0,HVAC_HDD_Accumulated);]]></Text>
</Rung>
<Rung Number="45" Type="N">
<Text><![CDATA[XIC(HMI_HVAC_Efficiency_Reset)MOV(0.0,HVAC_Efficiency_Pct);]]></Text>
</Rung>
<Rung Number="46" Type="N">
<Text><![CDATA[XIC(HMI_HVAC_Efficiency_Reset)OTU(HVAC_Efficiency_Alarm);]]></Text>
</Rung>
<Rung Number="47" Type="N">
<Text><![CDATA[XIC(HMI_HVAC_Efficiency_Reset)OTU(HMI_HVAC_Efficiency_Reset);]]></Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="Electrical_Monitor" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment><![CDATA[Copy current reading]]></Comment>
<Text><![CDATA[MOV(House_Current_Amps,Elec_Current_Amps);]]></Text>
</Rung>
<Rung Number="1" Type="N">
<Comment><![CDATA[Track peak current]]></Comment>
<Text><![CDATA[GRT(Elec_Current_Amps,Elec_Peak_Amps)MOV(Elec_Current_Amps,Elec_Peak_Amps);]]></Text>
</Rung>
<Rung Number="2" Type="N">
<Comment><![CDATA[Overload timer - sustained >180A for 5s]]></Comment>
<Text><![CDATA[GRT(Elec_Current_Amps,180.0)TON(Elec_Overload_Timer,5000,0);]]></Text>
</Rung>
<Rung Number="3" Type="N">
<Comment><![CDATA[Set overload alarm]]></Comment>
<Text><![CDATA[XIC(Elec_Overload_Timer.DN)OTL(Elec_Overload_Alarm);]]></Text>
</Rung>
<Rung Number="4" Type="N">
<Comment><![CDATA[Generator overload - sustained above threshold for 3s]]></Comment>
<Text><![CDATA[XIC(Gen_On_Generator)GRT(Elec_Current_Amps,Elec_Gen_Max_Amps)TON(Elec_Gen_Overload_Timer,3000,0);]]></Text>
</Rung>
<Rung Number="5" Type="N">
<Comment><![CDATA[Set generator overload alarm]]></Comment>
<Text><![CDATA[XIC(Elec_Gen_Overload_Timer.DN)OTL(Elec_Gen_Overload_Alarm);]]></Text>
</Rung>
<Rung Number="6" Type="N">
<Comment><![CDATA[Calculate watts this second]]></Comment>
<Text><![CDATA[XIC(Pulse_1s)MUL(Elec_Current_Amps,240.0,Elec_Watt_Seconds_Temp);]]></Text>
</Rung>
<Rung Number="7" Type="N">
<Comment><![CDATA[Add to watt-seconds accumulator]]></Comment>
<Text><![CDATA[XIC(Pulse_1s)ADD(Elec_Watt_Seconds,Elec_Watt_Seconds_Temp,Elec_Watt_Seconds);]]></Text>
</Rung>
<Rung Number="8" Type="N">
<Comment><![CDATA[Convert to kWh at 3600000 watt-seconds]]></Comment>
<Text><![CDATA[GEQ(Elec_Watt_Seconds,3600000.0)ADD(Elec_Total_kWh,1.0,Elec_Total_kWh);]]></Text>
</Rung>
<Rung Number="9" Type="N">
<Comment><![CDATA[Subtract 3600000 from accumulator]]></Comment>
<Text><![CDATA[GEQ(Elec_Watt_Seconds,3600000.0)SUB(Elec_Watt_Seconds,3600000.0,Elec_Watt_Seconds);]]></Text>
</Rung>
<Rung Number="10" Type="N">
<Comment><![CDATA[HMI peak current reset]]></Comment>
<Text><![CDATA[XIC(HMI_Elec_Peak_Reset)MOV(0.0,Elec_Peak_Amps);]]></Text>
</Rung>
<Rung Number="11" Type="N">
<Text><![CDATA[XIC(HMI_Elec_Peak_Reset)OTU(HMI_Elec_Peak_Reset);]]></Text>
</Rung>
<Rung Number="12" Type="N">
<Comment><![CDATA[HMI electrical alarm reset]]></Comment>
<Text><![CDATA[XIC(HMI_Elec_Alarm_Reset)OTU(Elec_Overload_Alarm);]]></Text>
</Rung>
<Rung Number="13" Type="N">
<Text><![CDATA[XIC(HMI_Elec_Alarm_Reset)OTU(Elec_Gen_Overload_Alarm);]]></Text>
</Rung>
<Rung Number="14" Type="N">
<Text><![CDATA[XIC(HMI_Elec_Alarm_Reset)OTU(HMI_Elec_Alarm_Reset);]]></Text>
</Rung>
<Rung Number="15" Type="N">
<Comment><![CDATA[Load shed timer - on generator and above threshold for 10s]]></Comment>
<Text><![CDATA[XIC(Gen_On_Generator)GRT(Elec_Current_Amps,Load_Shed_Threshold)TON(Load_Shed_Timer,10000,0);]]></Text>
</Rung>
<Rung Number="16" Type="N">
<Comment><![CDATA[Latch load shed active]]></Comment>
<Text><![CDATA[XIC(Load_Shed_Timer.DN)OTL(Load_Shed_Active);]]></Text>
</Rung>
<Rung Number="17" Type="N">
<Comment><![CDATA[Auto-clear load shed when not on generator or HMI reset]]></Comment>
<Text><![CDATA[[XIO(Gen_On_Generator),XIC(HMI_Load_Shed_Reset)]OTU(Load_Shed_Active);]]></Text>
</Rung>
<Rung Number="18" Type="N">
<Comment><![CDATA[Clear HMI load shed reset]]></Comment>
<Text><![CDATA[XIC(HMI_Load_Shed_Reset)OTU(HMI_Load_Shed_Reset);]]></Text>
</Rung>
<Rung Number="19" Type="N">
<Comment><![CDATA[Load shed HVAC output]]></Comment>
<Text><![CDATA[XIC(Load_Shed_Active)OTE(Load_Shed_HVAC);]]></Text>
</Rung>
<Rung Number="20" Type="N">
<Comment><![CDATA[Load shed non-critical 1 output]]></Comment>
<Text><![CDATA[XIC(Load_Shed_Active)OTE(Load_Shed_NonCritical1);]]></Text>
</Rung>
<Rung Number="21" Type="N">
<Comment><![CDATA[Load shed non-critical 2 output]]></Comment>
<Text><![CDATA[XIC(Load_Shed_Active)OTE(Load_Shed_NonCritical2);]]></Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="Leak_Detection" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment><![CDATA[Any leak zone active - latch alarm]]></Comment>
<Text><![CDATA[[XIC(Leak_Zone1),XIC(Leak_Zone2),XIC(Leak_Zone3)]OTL(Leak_Any_Alarm);]]></Text>
</Rung>
<Rung Number="1" Type="N">
<Comment><![CDATA[Reset leak alarm only when all zones clear]]></Comment>
<Text><![CDATA[XIC(HMI_Leak_Alarm_Reset)XIO(Leak_Zone1)XIO(Leak_Zone2)XIO(Leak_Zone3)OTU(Leak_Any_Alarm);]]></Text>
</Rung>
<Rung Number="2" Type="N">
<Comment><![CDATA[Clear HMI leak alarm reset]]></Comment>
<Text><![CDATA[XIC(HMI_Leak_Alarm_Reset)OTU(HMI_Leak_Alarm_Reset);]]></Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="Garage_Monitor" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment><![CDATA[Garage door open when not closed]]></Comment>
<Text><![CDATA[XIO(Garage_Door_Closed)OTE(Garage_Door_Open);]]></Text>
</Rung>
<Rung Number="1" Type="N">
<Comment><![CDATA[Track garage open duration]]></Comment>
<Text><![CDATA[XIC(Garage_Door_Open)XIC(Pulse_1s)ADD(Garage_Open_Seconds,1,Garage_Open_Seconds);]]></Text>
</Rung>
<Rung Number="2" Type="N">
<Comment><![CDATA[Reset open counter when door closed]]></Comment>
<Text><![CDATA[XIO(Garage_Door_Open)MOV(0,Garage_Open_Seconds);]]></Text>
</Rung>
<Rung Number="3" Type="N">
<Comment><![CDATA[Alarm when open too long]]></Comment>
<Text><![CDATA[GEQ(Garage_Open_Seconds,Garage_Open_Max_Seconds)OTL(Garage_Open_Alarm);]]></Text>
</Rung>
<Rung Number="4" Type="N">
<Comment><![CDATA[Reset garage alarm when door closed and HMI reset]]></Comment>
<Text><![CDATA[XIC(HMI_Garage_Alarm_Reset)XIC(Garage_Door_Closed)OTU(Garage_Open_Alarm);]]></Text>
</Rung>
<Rung Number="5" Type="N">
<Comment><![CDATA[Clear HMI garage alarm reset]]></Comment>
<Text><![CDATA[XIC(HMI_Garage_Alarm_Reset)OTU(HMI_Garage_Alarm_Reset);]]></Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="Well_Pump_Monitor" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment><![CDATA[Well pump short cycle detection window 60s]]></Comment>
<Text><![CDATA[XIO(Well_Pump_Running)TON(Well_Short_Cycle_Timer,60000,0);]]></Text>
</Rung>
<Rung Number="1" Type="N">
<Comment><![CDATA[Count well pump cycle on start]]></Comment>
<Text><![CDATA[XIC(Well_Pump_Running)XIO(Well_Pump_Cycle_ONS)ADD(Well_Pump_Cycle_Count,1,Well_Pump_Cycle_Count);]]></Text>
</Rung>
<Rung Number="2" Type="N">
<Comment><![CDATA[Set well pump cycle one-shot]]></Comment>
<Text><![CDATA[XIC(Well_Pump_Running)OTL(Well_Pump_Cycle_ONS);]]></Text>
</Rung>
<Rung Number="3" Type="N">
<Comment><![CDATA[Clear well pump cycle one-shot]]></Comment>
<Text><![CDATA[XIO(Well_Pump_Running)OTU(Well_Pump_Cycle_ONS);]]></Text>
</Rung>
<Rung Number="4" Type="N">
<Comment><![CDATA[Track well pump current run seconds]]></Comment>
<Text><![CDATA[XIC(Well_Pump_Running)XIC(Pulse_1s)ADD(Well_Pump_Current_Run_Seconds,1,Well_Pump_Current_Run_Seconds);]]></Text>
</Rung>
<Rung Number="5" Type="N">
<Comment><![CDATA[Save last run on pump stop]]></Comment>
<Text><![CDATA[XIO(Well_Pump_Running)XIC(Well_Pump_Cycle_ONS)MOV(Well_Pump_Current_Run_Seconds,Well_Pump_Last_Run_Seconds);]]></Text>
</Rung>
<Rung Number="6" Type="N">
<Comment><![CDATA[Short cycle detect - run less than minimum]]></Comment>
<Text><![CDATA[XIO(Well_Pump_Running)XIC(Well_Pump_Cycle_ONS)LES(Well_Pump_Current_Run_Seconds,Well_Pump_Min_Run_Seconds)ADD(Well_Pump_Short_Cycle_Count,1,Well_Pump_Short_Cycle_Count);]]></Text>
</Rung>
<Rung Number="7" Type="N">
<Comment><![CDATA[Clear short cycle count on normal run]]></Comment>
<Text><![CDATA[XIO(Well_Pump_Running)XIC(Well_Pump_Cycle_ONS)GEQ(Well_Pump_Current_Run_Seconds,Well_Pump_Min_Run_Seconds)MOV(0,Well_Pump_Short_Cycle_Count);]]></Text>
</Rung>
<Rung Number="8" Type="N">
<Comment><![CDATA[Clear current run seconds on pump stop]]></Comment>
<Text><![CDATA[XIO(Well_Pump_Running)MOV(0,Well_Pump_Current_Run_Seconds);]]></Text>
</Rung>
<Rung Number="9" Type="N">
<Comment><![CDATA[Short cycle alarm at 3 consecutive]]></Comment>
<Text><![CDATA[GEQ(Well_Pump_Short_Cycle_Count,3)OTL(Well_Pump_Short_Cycle_Alarm);]]></Text>
</Rung>
<Rung Number="10" Type="N">
<Comment><![CDATA[Low water pressure alarm]]></Comment>
<Text><![CDATA[LES(Water_Pressure_PSI,Water_Pressure_Low_SP)OTL(Water_Pressure_Low_Alarm);]]></Text>
</Rung>
<Rung Number="11" Type="N">
<Comment><![CDATA[Clear low pressure when above setpoint]]></Comment>
<Text><![CDATA[GEQ(Water_Pressure_PSI,Water_Pressure_Low_SP)OTU(Water_Pressure_Low_Alarm);]]></Text>
</Rung>
<Rung Number="12" Type="N">
<Comment><![CDATA[HMI well alarm reset - clear short cycle alarm]]></Comment>
<Text><![CDATA[XIC(HMI_Well_Alarm_Reset)OTU(Well_Pump_Short_Cycle_Alarm);]]></Text>
</Rung>
<Rung Number="13" Type="N">
<Comment><![CDATA[HMI well alarm reset - clear short cycle count]]></Comment>
<Text><![CDATA[XIC(HMI_Well_Alarm_Reset)MOV(0,Well_Pump_Short_Cycle_Count);]]></Text>
</Rung>
<Rung Number="14" Type="N">
<Comment><![CDATA[Clear HMI well alarm reset]]></Comment>
<Text><![CDATA[XIC(HMI_Well_Alarm_Reset)OTU(HMI_Well_Alarm_Reset);]]></Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="Maintenance_Monitor" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment><![CDATA[Track gen run seconds since oil change]]></Comment>
<Text><![CDATA[XIC(Gen_Running)XIC(Pulse_1s)ADD(Maint_Gen_Run_Since_Oil,1,Maint_Gen_Run_Since_Oil);]]></Text>
</Rung>
<Rung Number="1" Type="N">
<Comment><![CDATA[Convert gen run seconds to hours]]></Comment>
<Text><![CDATA[DIV(Maint_Gen_Run_Since_Oil,3600,Maint_Gen_Hours_Since_Oil);]]></Text>
</Rung>
<Rung Number="2" Type="N">
<Comment><![CDATA[Gen oil change due]]></Comment>
<Text><![CDATA[GEQ(Maint_Gen_Hours_Since_Oil,Maint_Gen_Oil_Hours)OTL(Maint_Gen_Oil_Due);]]></Text>
</Rung>
<Rung Number="3" Type="N">
<Comment><![CDATA[HMI gen oil reset]]></Comment>
<Text><![CDATA[XIC(HMI_Maint_Gen_Oil_Reset)MOV(0,Maint_Gen_Run_Since_Oil);]]></Text>
</Rung>
<Rung Number="4" Type="N">
<Text><![CDATA[XIC(HMI_Maint_Gen_Oil_Reset)OTU(Maint_Gen_Oil_Due);]]></Text>
</Rung>
<Rung Number="5" Type="N">
<Text><![CDATA[XIC(HMI_Maint_Gen_Oil_Reset)OTU(HMI_Maint_Gen_Oil_Reset);]]></Text>
</Rung>
<Rung Number="6" Type="N">
<Comment><![CDATA[Track sump cycles since inspection]]></Comment>
<Text><![CDATA[XIC(Sump_Pump_Run)XIO(Maint_Sump_Cycle_ONS)ADD(Maint_Sump_Cycles_Since_Inspect,1,Maint_Sump_Cycles_Since_Inspect);]]></Text>
</Rung>
<Rung Number="7" Type="N">
<Comment><![CDATA[Set maint sump cycle one-shot]]></Comment>
<Text><![CDATA[XIC(Sump_Pump_Run)OTL(Maint_Sump_Cycle_ONS);]]></Text>
</Rung>
<Rung Number="8" Type="N">
<Comment><![CDATA[Clear maint sump cycle one-shot]]></Comment>
<Text><![CDATA[XIO(Sump_Pump_Run)OTU(Maint_Sump_Cycle_ONS);]]></Text>
</Rung>
<Rung Number="9" Type="N">
<Comment><![CDATA[Sump inspection due]]></Comment>
<Text><![CDATA[GEQ(Maint_Sump_Cycles_Since_Inspect,Maint_Sump_Inspect_Cycles)OTL(Maint_Sump_Inspect_Due);]]></Text>
</Rung>
<Rung Number="10" Type="N">
<Comment><![CDATA[HMI sump inspect reset - clear cycle counter]]></Comment>
<Text><![CDATA[XIC(HMI_Maint_Sump_Reset)MOV(0,Maint_Sump_Cycles_Since_Inspect);]]></Text>
</Rung>
<Rung Number="11" Type="N">
<Text><![CDATA[XIC(HMI_Maint_Sump_Reset)OTU(Maint_Sump_Inspect_Due);]]></Text>
</Rung>
<Rung Number="12" Type="N">
<Text><![CDATA[XIC(HMI_Maint_Sump_Reset)OTU(HMI_Maint_Sump_Reset);]]></Text>
</Rung>
<Rung Number="13" Type="N">
<Comment><![CDATA[Track furnace run seconds since inspection]]></Comment>
<Text><![CDATA[XIC(HVAC_Furnace_Running)XIC(Pulse_1s)ADD(Maint_Furnace_Run_Since_Inspect,1,Maint_Furnace_Run_Since_Inspect);]]></Text>
</Rung>
<Rung Number="14" Type="N">
<Comment><![CDATA[Convert furnace run seconds to hours]]></Comment>
<Text><![CDATA[DIV(Maint_Furnace_Run_Since_Inspect,3600,Maint_Furnace_Hours_Since_Inspect);]]></Text>
</Rung>
<Rung Number="15" Type="N">
<Comment><![CDATA[Furnace inspection due]]></Comment>
<Text><![CDATA[GEQ(Maint_Furnace_Hours_Since_Inspect,Maint_Furnace_Inspect_Hours)OTL(Maint_Furnace_Inspect_Due);]]></Text>
</Rung>
<Rung Number="16" Type="N">
<Comment><![CDATA[HMI furnace inspect reset]]></Comment>
<Text><![CDATA[XIC(HMI_Maint_Furnace_Reset)MOV(0,Maint_Furnace_Run_Since_Inspect);]]></Text>
</Rung>
<Rung Number="17" Type="N">
<Text><![CDATA[XIC(HMI_Maint_Furnace_Reset)OTU(Maint_Furnace_Inspect_Due);]]></Text>
</Rung>
<Rung Number="18" Type="N">
<Text><![CDATA[XIC(HMI_Maint_Furnace_Reset)OTU(HMI_Maint_Furnace_Reset);]]></Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="HMI_Interface" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment><![CDATA[Generator state to HMI]]></Comment>
<Text><![CDATA[MOV(Gen_State,HMI_Gen_State);]]></Text>
</Rung>
<Rung Number="1" Type="N">
<Comment><![CDATA[Generator running to HMI]]></Comment>
<Text><![CDATA[XIC(Gen_Running)OTE(HMI_Gen_Running);]]></Text>
</Rung>
<Rung Number="2" Type="N">
<Comment><![CDATA[On utility to HMI]]></Comment>
<Text><![CDATA[XIC(Gen_On_Utility)OTE(HMI_Gen_On_Utility);]]></Text>
</Rung>
<Rung Number="3" Type="N">
<Comment><![CDATA[On generator to HMI]]></Comment>
<Text><![CDATA[XIC(Gen_On_Generator)OTE(HMI_Gen_On_Generator);]]></Text>
</Rung>
<Rung Number="4" Type="N">
<Comment><![CDATA[Exercise active to HMI]]></Comment>
<Text><![CDATA[XIC(Gen_Exercise_Active)OTE(HMI_Gen_Exercise_Active);]]></Text>
</Rung>
<Rung Number="5" Type="N">
<Comment><![CDATA[Start fail alarm to HMI]]></Comment>
<Text><![CDATA[XIC(Gen_Start_Fail)OTE(HMI_Gen_Start_Fail_Alarm);]]></Text>
</Rung>
<Rung Number="6" Type="N">
<Comment><![CDATA[Stop fail alarm to HMI]]></Comment>
<Text><![CDATA[XIC(Gen_Stop_Fail)OTE(HMI_Gen_Stop_Fail_Alarm);]]></Text>
</Rung>
<Rung Number="7" Type="N">
<Comment><![CDATA[Gen fault alarm to HMI]]></Comment>
<Text><![CDATA[XIC(Gen_Fault)OTE(HMI_Gen_Fault_Alarm);]]></Text>
</Rung>
<Rung Number="8" Type="N">
<Comment><![CDATA[Utility present to HMI]]></Comment>
<Text><![CDATA[XIC(Utility_Power_Present)OTE(HMI_Utility_Present);]]></Text>
</Rung>
<Rung Number="9" Type="N">
<Comment><![CDATA[Gen run hours to HMI (seconds / 3600)]]></Comment>
<Text><![CDATA[DIV(Gen_Total_Run_Seconds,3600,HMI_Gen_Total_Run_Hours);]]></Text>
</Rung>
<Rung Number="10" Type="N">
<Comment><![CDATA[Gen crank attempts to HMI]]></Comment>
<Text><![CDATA[MOV(Gen_Crank_Attempts,HMI_Gen_Crank_Attempts);]]></Text>
</Rung>
<Rung Number="11" Type="N">
<Comment><![CDATA[Sump state to HMI]]></Comment>
<Text><![CDATA[MOV(Sump_State,HMI_Sump_State);]]></Text>
</Rung>
<Rung Number="12" Type="N">
<Comment><![CDATA[Sump pump running to HMI]]></Comment>
<Text><![CDATA[XIC(Sump_Pump_Run)OTE(HMI_Sump_Pump_Running);]]></Text>
</Rung>
<Rung Number="13" Type="N">
<Comment><![CDATA[Sump float active to HMI]]></Comment>
<Text><![CDATA[XIC(Sump_Float_High)OTE(HMI_Sump_Float_Active);]]></Text>
</Rung>
<Rung Number="14" Type="N">
<Comment><![CDATA[Sump test active to HMI]]></Comment>
<Text><![CDATA[XIC(Sump_Test_Active)OTE(HMI_Sump_Test_Active);]]></Text>
</Rung>
<Rung Number="15" Type="N">
<Comment><![CDATA[Sump max run alarm to HMI]]></Comment>
<Text><![CDATA[XIC(Sump_Max_Run_Fault)OTE(HMI_Sump_Max_Run_Alarm);]]></Text>
</Rung>
<Rung Number="16" Type="N">
<Comment><![CDATA[Sump cycle count to HMI]]></Comment>
<Text><![CDATA[MOV(Sump_Cycle_Count,HMI_Sump_Cycle_Count);]]></Text>
</Rung>
<Rung Number="17" Type="N">
<Comment><![CDATA[Sump run hours to HMI]]></Comment>
<Text><![CDATA[DIV(Sump_Total_Run_Seconds,3600,HMI_Sump_Total_Run_Hours);]]></Text>
</Rung>
<Rung Number="18" Type="N">
<Comment><![CDATA[Sump last run to HMI]]></Comment>
<Text><![CDATA[MOV(Sump_Last_Run_Seconds,HMI_Sump_Last_Run_Seconds);]]></Text>
</Rung>
<Rung Number="19" Type="N">
<Comment><![CDATA[Sump last test OK to HMI]]></Comment>
<Text><![CDATA[XIC(Sump_Last_Test_OK)OTE(HMI_Sump_Last_Test_OK);]]></Text>
</Rung>
<Rung Number="20" Type="N">
<Comment><![CDATA[Furnace running to HMI]]></Comment>
<Text><![CDATA[XIC(HVAC_Furnace_Running)OTE(HMI_HVAC_Furnace_Running);]]></Text>
</Rung>
<Rung Number="21" Type="N">
<Comment><![CDATA[HVAC cycle count to HMI]]></Comment>
<Text><![CDATA[MOV(HVAC_Cycle_Count,HMI_HVAC_Cycle_Count);]]></Text>
</Rung>
<Rung Number="22" Type="N">
<Comment><![CDATA[HVAC run hours to HMI]]></Comment>
<Text><![CDATA[DIV(HVAC_Total_Run_Seconds,3600,HMI_HVAC_Total_Run_Hours);]]></Text>
</Rung>
<Rung Number="23" Type="N">
<Comment><![CDATA[HVAC last run to HMI]]></Comment>
<Text><![CDATA[MOV(HVAC_Last_Run_Seconds,HMI_HVAC_Last_Run_Seconds);]]></Text>
</Rung>
<Rung Number="24" Type="N">
<Comment><![CDATA[Filter run hours to HMI]]></Comment>
<Text><![CDATA[DIV(HVAC_Filter_Run_Seconds,3600,HMI_HVAC_Filter_Run_Hours);]]></Text>
</Rung>
<Rung Number="25" Type="N">
<Comment><![CDATA[Filter change due to HMI]]></Comment>
<Text><![CDATA[XIC(HVAC_Filter_Change_Due)OTE(HMI_HVAC_Filter_Change_Due);]]></Text>
</Rung>
<Rung Number="26" Type="N">
<Comment><![CDATA[Short cycle alarm to HMI]]></Comment>
<Text><![CDATA[XIC(HVAC_Short_Cycle_Alarm)OTE(HMI_HVAC_Short_Cycle_Alarm);]]></Text>
</Rung>
<Rung Number="27" Type="N">
<Comment><![CDATA[Outdoor temp to HMI]]></Comment>
<Text><![CDATA[MOV(Outdoor_Temp_F,HMI_Outdoor_Temp);]]></Text>
</Rung>
<Rung Number="28" Type="N">
<Comment><![CDATA[Outdoor temp min to HMI]]></Comment>
<Text><![CDATA[MOV(HVAC_Outdoor_Temp_Min,HMI_Outdoor_Temp_Min);]]></Text>
</Rung>
<Rung Number="29" Type="N">
<Comment><![CDATA[Outdoor temp max to HMI]]></Comment>
<Text><![CDATA[MOV(HVAC_Outdoor_Temp_Max,HMI_Outdoor_Temp_Max);]]></Text>
</Rung>
<Rung Number="30" Type="N">
<Comment><![CDATA[Current amps to HMI]]></Comment>
<Text><![CDATA[MOV(Elec_Current_Amps,HMI_Elec_Current_Amps);]]></Text>
</Rung>
<Rung Number="31" Type="N">
<Comment><![CDATA[Peak amps to HMI]]></Comment>
<Text><![CDATA[MOV(Elec_Peak_Amps,HMI_Elec_Peak_Amps);]]></Text>
</Rung>
<Rung Number="32" Type="N">
<Comment><![CDATA[Total kWh to HMI]]></Comment>
<Text><![CDATA[MOV(Elec_Total_kWh,HMI_Elec_Total_kWh);]]></Text>
</Rung>
<Rung Number="33" Type="N">
<Comment><![CDATA[Overload alarm to HMI]]></Comment>
<Text><![CDATA[XIC(Elec_Overload_Alarm)OTE(HMI_Elec_Overload_Alarm);]]></Text>
</Rung>
<Rung Number="34" Type="N">
<Comment><![CDATA[Gen overload alarm to HMI]]></Comment>
<Text><![CDATA[XIC(Elec_Gen_Overload_Alarm)OTE(HMI_Elec_Gen_Overload_Alarm);]]></Text>
</Rung>
<Rung Number="35" Type="N">
<Comment><![CDATA[Freeze warning to HMI]]></Comment>
<Text><![CDATA[XIC(Freeze_Warning)OTE(HMI_Freeze_Warning);]]></Text>
</Rung>
<Rung Number="36" Type="N">
<Comment><![CDATA[Freeze critical to HMI]]></Comment>
<Text><![CDATA[XIC(Freeze_Critical)OTE(HMI_Freeze_Critical);]]></Text>
</Rung>
<Rung Number="37" Type="N">
<Comment><![CDATA[Sump cycle rate alarm to HMI]]></Comment>
<Text><![CDATA[XIC(Sump_Cycle_Rate_Alarm)OTE(HMI_Sump_Cycle_Rate_Alarm);]]></Text>
</Rung>
<Rung Number="38" Type="N">
<Comment><![CDATA[Leak alarm to HMI]]></Comment>
<Text><![CDATA[XIC(Leak_Any_Alarm)OTE(HMI_Leak_Any_Alarm);]]></Text>
</Rung>
<Rung Number="39" Type="N">
<Comment><![CDATA[Garage open alarm to HMI]]></Comment>
<Text><![CDATA[XIC(Garage_Open_Alarm)OTE(HMI_Garage_Open_Alarm);]]></Text>
</Rung>
<Rung Number="40" Type="N">
<Comment><![CDATA[Garage open seconds to HMI]]></Comment>
<Text><![CDATA[MOV(Garage_Open_Seconds,HMI_Garage_Open_Seconds);]]></Text>
</Rung>
<Rung Number="41" Type="N">
<Comment><![CDATA[Well pump running to HMI]]></Comment>
<Text><![CDATA[XIC(Well_Pump_Running)OTE(HMI_Well_Pump_Running);]]></Text>
</Rung>
<Rung Number="42" Type="N">
<Comment><![CDATA[Well pump short cycle alarm to HMI]]></Comment>
<Text><![CDATA[XIC(Well_Pump_Short_Cycle_Alarm)OTE(HMI_Well_Short_Cycle_Alarm);]]></Text>
</Rung>
<Rung Number="43" Type="N">
<Comment><![CDATA[Water pressure low alarm to HMI]]></Comment>
